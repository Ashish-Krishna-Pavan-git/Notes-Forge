{
  "app": {
    "name": "NotesForge Professional",
    "version": "6.2",
    "theme": "corporate"
  },
  "fonts": {
    "family": "Arial",
    "family_code": "Consolas",
    "h1_family": "Arial",
    "h2_family": "Arial",
    "h3_family": "Arial",
    "h4_family": "Trebuchet MS",
    "h5_family": "Trebuchet MS",
    "h6_family": "Trebuchet MS",
    "bullet_family": "Tahoma",
    "sizes": {
      "h1": 26,
      "h2": 20,
      "h3": 16,
      "h4": 14,
      "h5": 13,
      "h6": 12,
      "body": 11,
      "code": 10,
      "header": 10,
      "footer": 9
    }
  },
  "colors": {
    "h1": "#C41E3A",
    "h2": "#DC143C",
    "h3": "#E63946",
    "h4": "#CC5500",
    "h5": "#333333",
    "h6": "#555555",
    "body": "#1F1F1F",
    "code_background": "#2C3E50",
    "code_text": "#ECF0F1",
    "table_header_bg": "#C41E3A",
    "table_header_text": "#FFFFFF",
    "table_odd_row": "#FCE8E8",
    "table_even_row": "#FFFFFF",
    "table_border": "#DC143C",
    "link": "#C41E3A"
  },
  "spacing": {
    "line_spacing": 1.6,
    "paragraph_spacing_before": 0,
    "paragraph_spacing_after": 10.0,
    "heading_spacing_before": 14.0,
    "heading_spacing_after": 8.0,
    "paragraph_first_line_indent": 0,
    "bullet_base_indent": 0.5,
    "bullet_indent_per_level": 0.75,
    "code_indent": 0.35,
    "quote_indent": 0.5,
    "paragraph_alignment": "left"
  },
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margins": {
      "top": 1.25,
      "bottom": 1.25,
      "left": 1.25,
      "right": 1.25
    },
    "border": {
      "enabled": true,
      "width": 3,
      "color": "#C41E3A",
      "style": "double",
      "offset": 24
    }
  },
  "watermark": {
    "enabled": true,
    "type": "text",
    "text": "INTERNAL USE ONLY",
    "image_path": "",
    "font": "Calibri",
    "size": 48,
    "color": "#C41E3A",
    "opacity": 0.08,
    "rotation": 315,
    "position": "center",
    "scale": 100
  },
  "header": {
    "enabled": true,
    "text": "CORPORATE DOCUMENT",
    "alignment": "center",
    "font_family": "Arial",
    "size": 12,
    "color": "#C41E3A",
    "bold": true,
    "italic": false,
    "separator": true,
    "separator_color": "#CCCCCC",
    "show_page_numbers": false,
    "page_number_position": "header",
    "page_number_alignment": "center",
    "page_number_style": "arabic",
    "page_format": "X | Page"
  },
  "footer": {
    "enabled": true,
    "text": "© 2026 Corporation. All Rights Reserved.",
    "alignment": "center",
    "font_family": "Arial",
    "size": 9,
    "color": "#666666",
    "bold": false,
    "italic": false,
    "separator": true,
    "separator_color": "#CCCCCC",
    "show_page_numbers": true,
    "page_number_position": "footer",
    "page_number_alignment": "center",
    "page_number_style": "arabic",
    "page_format": "X | Page"
  }
}