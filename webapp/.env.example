# Backend CORS origins (comma-separated)
NF_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://notes-forge-ruddy.vercel.app,https://notes-forge.onrender.com

# Backend host/port/runtime
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=10000
DOCX_TEMP_DIR=./backend/.notesforge_tmp
STORAGE_BACKEND=local
NF_PDF_ALLOW_LOW_FIDELITY_FALLBACK=0
NF_PDF_PROVIDER=ilovepdf
NF_ILOVEPDF_PUBLIC_KEY=
NF_ILOVEPDF_REGION=us
NF_ILOVEPDF_AUTOMATION_URL=
NF_ILOVEPDF_WORD_TO_PDF_URL=
NF_ILOVEPDF_PDF_TO_WORD_URL=
NF_ILOVEPDF_REMOTE_AUTH_HEADER=Authorization
NF_ILOVEPDF_REMOTE_AUTH_SCHEME=Bearer
NF_ILOVEPDF_REMOTE_AUTH_TOKEN=
NF_SMALLPDF_WORD_TO_PDF_URL=
NF_SMALLPDF_PDF_TO_WORD_URL=
NF_SMALLPDF_AUTH_HEADER=Authorization
NF_SMALLPDF_AUTH_SCHEME=Bearer
NF_SMALLPDF_AUTH_TOKEN=
NF_ENABLE_SERVER_FILE_DISCOVERY=0
NF_FILE_DISCOVERY_MAX_FILES=6
NF_PROCESSING_MAX_UPLOAD_BYTES=104857600
NF_SERVE_FRONTEND=0
NF_FRONTEND_DIST=
NF_APP_DATA_DIR=

# Frontend API base URL
VITE_API_URL=http://localhost:10000
